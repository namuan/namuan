{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/specops/compiled-spec-schema.json",
  "title": "SpecOps Compiled Spec",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "specVersion",
    "featureName",
    "actors",
    "scenarios",
    "dataModels"
  ],
  "properties": {
    "specVersion": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+(?:\\.[0-9]+)?$"
    },
    "featureName": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "actors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "properties"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 100
          },
          "properties": {
            "type": "object",
            "additionalProperties": {
              "type": ["string", "number", "integer", "boolean", "null"]
            }
          }
        }
      }
    },
    "scenarios": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "description", "given", "when", "then"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^SC-[0-9]{3,}$"
          },
          "description": {
            "type": "string",
            "minLength": 1,
            "maxLength": 300
          },
          "given": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1000
          },
          "when": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1000
          },
          "then": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1,
              "maxLength": 1000
            }
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1,
              "maxLength": 50
            }
          }
        }
      }
    },
    "dataModels": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["fields"],
        "properties": {
          "fields": {
            "type": "object",
            "minProperties": 1,
            "additionalProperties": {
              "type": "object",
              "additionalProperties": false,
              "required": ["type", "required"],
              "properties": {
                "type": {
                  "type": "string",
                  "enum": [
                    "string",
                    "number",
                    "integer",
                    "boolean",
                    "array",
                    "object"
                  ]
                },
                "required": {
                  "type": "boolean"
                },
                "description": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 500
                },
                "format": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 100
                },
                "maxLength": {
                  "type": "integer",
                  "minimum": 0
                },
                "minLength": {
                  "type": "integer",
                  "minimum": 0
                },
                "minimum": {
                  "type": "number"
                },
                "maximum": {
                  "type": "number"
                },
                "items": {
                  "type": "object",
                  "additionalProperties": true
                }
              }
            }
          }
        }
      }
    },
    "nonFunctionalRequirements": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 500
      }
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 500
      }
    }
  }
}